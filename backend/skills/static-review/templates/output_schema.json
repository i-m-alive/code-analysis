{
  "type": "object",
  "required": ["issues"],
  "properties": {
    "issues": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["severity", "line", "issue", "recommendation", "confidence"],
        "properties": {
          "severity": {
            "type": "string",
            "enum": ["info", "low", "medium", "high", "critical"]
          },
          "line": { "type": "string" },
          "issue": { "type": "string" },
          "recommendation": { "type": "string" },
          "category": {
            "type": "string",
            "enum": ["correctness", "security", "maintainability", "performance", "style"]
          },
          "confidence": {
            "type": "integer",
            "minimum": 0,
            "maximum": 100,
            "description": "How sure you are this finding is real. 95+=certain, 75-94=likely, <70=do NOT report."
          }
        }
      }
    }
  }
}
